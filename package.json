{
  "name": "@weburz/carousel",
  "version": "0.0.1",
  "description": "Carousel components for Nuxt 4 — YouTube, Instagram, TikTok embeds with the platform lifecycle done right. Built on Embla.",
  "keywords": [
    "nuxt",
    "nuxt-module",
    "vue",
    "typescript",
    "carousel",
    "embla",
    "youtube",
    "instagram",
    "tiktok",
    "embed"
  ],
  "license": "MIT",
  "author": "Weburz",
  "homepage": "https://github.com/Weburz/carousel#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Weburz/carousel.git"
  },
  "bugs": {
    "url": "https://github.com/Weburz/carousel/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "setup:hooks": "pre-commit install && pre-commit install --hook-type commit-msg"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.5",
    "embla-carousel": "^8.6.0",
    "embla-carousel-vue": "^8.6.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.5",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "^24",
    "changelogen": "^0.6.2",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "nuxt": "^4.4.5",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
